{
  "name": "scraper-server",
  "version": "1.0.0",
  "description": "Kontakt Home Spesifikasiya Skraperi",
  "main": "main-electron.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron main-electron.js",
    "build:exe": "electron-builder build --win --x64",
    "dev": "nodemon server.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "fs-extra": "^11.3.3",
    "puppeteer": "^24.37.5",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "nodemon": "^3.1.14"
  },
  "build": {
    "appId": "com.kontakt.scraper",
    "productName": "Kontakt Scraper",
    "win": {
      "target": "portable",
      "icon": "public/icon.ico"
    },
    "files": [
      "**/*",
      "!dist/*",
      "!Dockerfile",
      "!.dockerignore"
    ],
    "extraResources": [
      "public/**/*"
    ]
  }
}